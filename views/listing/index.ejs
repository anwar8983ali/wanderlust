<% layout('layouts/boilerPlate') %>
   <style>
    #filters{
      margin-top: 1rem;
      display: flex;
      align-items: center;
      margin-left: 2rem;
    }

    .filter{
      text-align:center;
      margin-right:2rem;
      margin-top:2rem;
      opacity: 0.7;
      cursor: pointer;
    }

    .filter:hover{
      opacity:1;
    }

    .active-filter{
      opacity: 1 !important;
      border-bottom: 2px solid black;
    }

     p {
      font-size:0.8rem;
    }

    .tax-info{
      display: none;
    }

    .tax-toggle{
      border:1px solid black;
      border-radius:1rem;
      height: fit-content;
      padding:0.75rem 1rem;
      display: flex;
      align-items: center;
      white-space: nowrap;
      flex-shrink: 0;
      margin-top: 2rem;
    }

    #nearMeBtn{
      cursor: pointer;
      border: none;
      background: none;
      font-family: inherit;
    }

    #radiusSelect{
      margin-top: 2rem;
      margin-right: 2rem;
      padding: 6px 10px;
      border-radius: 8px;
      border: 1px solid #ccc;
      font-size: 0.85rem;
      height: fit-content;
      align-self: center;
    }

    .distance-badge{
      display: inline-block;
      background: #e1f5ee;
      color: #085041;
      font-size: 0.75rem;
      padding: 2px 8px;
      border-radius: 6px;
      margin-top: 4px;
    }

   </style>
   <div id="filters">
       <button class="filter" id="nearMeBtn" style="border:none;">
        <div><i class="fa-solid fa-location-crosshairs"></i></div>
        <p>Near me</p>
       </button>

       <select id="radiusSelect">
         <option value="10">Within 10 km</option>
         <option value="50">Within 50 km</option>
         <option value="100" selected>Within 100 km</option>
         <option value="500">Within 500 km</option>
         <option value="0">Anywhere</option>
       </select>

       <a href="/listings?category=Trending" class="filter text-decoration-none text-dark <%= (!activeCategory || activeCategory === 'Trending') ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>
       </a>

       <a href="/listings?category=Rooms" class="filter text-decoration-none text-dark <%= activeCategory === 'Rooms' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Rooms</p>
       </a>

       <a href="/listings?category=Iconic%20cities" class="filter text-decoration-none text-dark <%= activeCategory === 'Iconic cities' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>Iconic cities</p>
       </a>

       <a href="/listings?category=Mountains" class="filter text-decoration-none text-dark <%= activeCategory === 'Mountains' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountains</p>
       </a>

       <a href="/listings?category=Castles" class="filter text-decoration-none text-dark <%= activeCategory === 'Castles' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-chess-rook"></i></div>
        <p>Castles</p>
       </a>

       <a href="/listings?category=Amazing%20pools" class="filter text-decoration-none text-dark <%= activeCategory === 'Amazing pools' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing pools</p>
       </a>

        <a href="/listings?category=Farms" class="filter text-decoration-none text-dark <%= activeCategory === 'Farms' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-cow"></i></div>
        <p>Farms</p>
       </a>

       <a href="/listings?category=Camping" class="filter text-decoration-none text-dark <%= activeCategory === 'Camping' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Camping</p>
       </a>

       <a href="/listings?category=Arctic" class="filter text-decoration-none text-dark <%= activeCategory === 'Arctic' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-snowflake"></i></div>
        <p>Arctic</p>
       </a>

       <a href="/listings?category=Domes" class="filter text-decoration-none text-dark <%= activeCategory === 'Domes' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-igloo"></i></div>
        <p>Domes</p>
       </a>

       <a href="/listings?category=Boats" class="filter text-decoration-none text-dark <%= activeCategory === 'Boats' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-sailboat"></i></div>
        <p>Boats</p>
       </a>

       <div class="tax-toggle">
         <div class="form-check form-switch form-check-reverse">
          <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
          <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
        </div>
       </div>

   </div>

   <% if (typeof isNearMe !== 'undefined' && isNearMe) { %>
     <p style="margin: 1rem 0 0 2rem; color: #666;">
       <i class="fa-solid fa-location-dot"></i> Showing listings sorted by distance from your location
       <% if (typeof radius !== 'undefined' && radius) { %>
         (within <%= radius %> km)
       <% } %>
     </p>
   <% } %>

   <% if (activeCategory && activeCategory !== 'Trending') { %>
     <p style="margin: 1rem 0 0 2rem; color: #666;">
       Showing: <strong><%= activeCategory %></strong> &middot; <a href="/listings">Clear filter</a>
     </p>
   <% } %>

  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for (let listing of allListings) {
         if (!listing._id || !listing.image || !listing.image.url) continue;
    %>
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card listing-card position-relative">
          <% if (currUser) { %>
            <button class="favorite-btn" data-id="<%= listing._id %>"
              style="position:absolute; top:10px; right:10px; z-index:10; background:rgba(255,255,255,0.9); border:none; border-radius:50%; width:36px; height:36px;"
              onclick="event.preventDefault(); event.stopPropagation(); toggleFavorite('<%= listing._id %>', this)">
              <i class="<%= currUser.favorites && currUser.favorites.some(f => f.equals(listing._id)) ? 'fas' : 'far' %> fa-heart" style="color:#fe424d;"></i>
            </button>
          <% } %>
          <img src="<%= listing.image.url %>" class="card-img-top" alt="listingImage" style="height:20rem;">
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b><br>
              &#8377; <%= listing.price.toLocaleString("en-IN") %>/night
              <i class="tax-info">  &nbsp;&nbsp;+18% GST</i>
              <% if (listing.avgRating) { %>
                <br><span style="color:#fe424d;">★ <%= listing.avgRating %></span>
              <% } %>
              <% if (listing.distanceKm) { %>
                <br><span class="distance-badge"><%= listing.distanceKm %> km away</span>
              <% } %>
            </p>
          </div>
        </div>
      </a>
    <% } %>

    <% if (typeof isNearMe !== 'undefined' && isNearMe && allListings.length === 0) { %>
      <div class="col-12 mt-4">
        <div class="alert alert-info">No listings found within this distance. Try a wider radius.</div>
      </div>
    <% } %>

    <% if (activeCategory && activeCategory !== 'Trending' && allListings.length === 0) { %>
      <div class="col-12 mt-4">
        <div class="alert alert-info">No listings found in this category yet.</div>
      </div>
    <% } %>
  </div>

  <div id="searchResults"></div>

  <script>
    let taxSwitch=document.getElementById('switchCheckDefault');

    taxSwitch.addEventListener('click',()=>{
      let taxInfo=document.getElementsByClassName('tax-info');
      for(info of taxInfo){
        if(info.style.display!="inline"){
          info.style.display="inline";
        } else {
          info.style.display="none";
        }
      }
    })

    document.getElementById('nearMeBtn').addEventListener('click', () => {
      if (!navigator.geolocation) {
        alert("Geolocation is not supported by your browser");
        return;
      }
      const radius = document.getElementById('radiusSelect').value;
      navigator.geolocation.getCurrentPosition(
        (position) => {
          const lat = position.coords.latitude;
          const lng = position.coords.longitude;
          const radiusParam = radius === "0" ? "" : `&radius=${radius}`;
          window.location.href = `/listings/near-me?lat=${lat}&lng=${lng}${radiusParam}`;
        },
        () => {
          alert("Unable to retrieve your location. Please allow location access in your browser.");
        }
      );
    });

    async function toggleFavorite(listingId, btn) {
      const res = await fetch(`/listings/${listingId}/favorite`, {
        method: 'POST',
        headers: { 'Accept': 'application/json' }
      });
      const data = await res.json();
      const icon = btn.querySelector('i');
      icon.className = data.favorited ? 'fas fa-heart' : 'far fa-heart';
    }
  </script>