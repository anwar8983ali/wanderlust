<% layout('layouts/boilerPlate') %>
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Manage Listings</h3>
    <a href="/admin" class="btn btn-sm btn-outline-secondary">&larr; Back to dashboard</a>
  </div>

  <table class="table table-hover align-middle">
    <thead>
      <tr>
        <th>Title</th>
        <th>Owner</th>
        <th>Price</th>
        <th>Category</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% listings.forEach(listing => { %>
        <tr>
          <td><a href="/listings/<%= listing._id %>"><%= listing.title %></a></td>
          <td><%= listing.owner ? listing.owner.username : "Unknown" %></td>
          <td>&#8377;<%= listing.price.toLocaleString("en-IN") %></td>
          <td><%= listing.category %></td>
          <td>
            <form action="/admin/listings/<%= listing._id %>/delete" method="POST" onsubmit="return confirm('Delete this listing permanently?')">
              <button class="btn btn-sm btn-outline-danger">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
