<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            background: linear-gradient(135deg,#0d6efd,#6f42c1);
            min-height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
        }

        .card{
            width:420px;
            border:none;
            border-radius:20px;
            box-shadow:0 20px 40px rgba(0,0,0,.2);
        }

        .logo{
            width:80px;
            height:80px;
            background:#0d6efd;
            color:white;
            border-radius:50%;
            display:flex;
            justify-content:center;
            align-items:center;
            font-size:35px;
            margin:auto;
        }

        .btn-send{
            border-radius:10px;
            padding:10px;
            font-weight:600;
        }

        .form-control{
            border-radius:10px;
        }

        a{
            text-decoration:none;
        }
    </style>
</head>

<body>

<div class="card p-4">

    <div class="logo mb-3">
        🔒
    </div>

    <h2 class="text-center fw-bold">Forgot Password?</h2>

    <p class="text-center text-muted mb-4">
        Enter your registered email address.<br>
        We'll send you a One-Time Password (OTP).
    </p>

    <form action="/forgot-password" method="POST">

        <div class="mb-3">
            <label class="form-label">Email Address</label>

            <input
                type="email"
                class="form-control"
                name="email"
                placeholder="example@gmail.com"
                required
            >
        </div>

        <button class="btn btn-primary w-100 btn-send">
            Send OTP
        </button>

    </form>

    <hr>

    <div class="text-center">

        <a href="/login">
            ← Back to Login
        </a>

    </div>

</div>

</body>
</html>